{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/agent-handoff-record.schema.json",
  "title": "Agent Handoff Record",
  "description": "A gate-aware handoff record for AI agents consuming Origin Trace Receipts.",
  "type": "object",
  "required": [
    "schema_version",
    "record_type",
    "handoff_id",
    "created_at",
    "source_receipt",
    "agent_context",
    "intake",
    "gate_check",
    "routing",
    "route_authorization",
    "reviewer_notification",
    "handoff_receipt_emission",
    "action_policy",
    "handoff_result"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.4.0"
    },
    "record_type": {
      "type": "string",
      "const": "origin_trace_agent_handoff"
    },
    "handoff_id": {
      "type": "string",
      "pattern": "^agent_handoff_[A-Za-z0-9._-]+$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_receipt": {
      "type": "object",
      "required": [
        "receipt_id",
        "receipt_schema_version",
        "receipt_reference",
        "receipt_status"
      ],
      "additionalProperties": false,
      "properties": {
        "receipt_id": {
          "type": "string",
          "pattern": "^otr_[A-Za-z0-9._-]+$"
        },
        "receipt_schema_version": {
          "type": "string"
        },
        "receipt_reference": {
          "type": "string"
        },
        "receipt_status": {
          "type": "string",
          "enum": [
            "draft",
            "validated",
            "rejected",
            "unknown"
          ]
        }
      }
    },
    "agent_context": {
      "type": "object",
      "required": [
        "agent_id",
        "agent_type",
        "agent_role",
        "autonomy_level"
      ],
      "additionalProperties": false,
      "properties": {
        "agent_id": {
          "type": "string",
          "pattern": "^agent_[A-Za-z0-9._-]+$"
        },
        "agent_type": {
          "type": "string",
          "enum": [
            "audit_agent",
            "routing_agent",
            "market_agent",
            "royalty_agent",
            "license_agent",
            "orchestration_agent",
            "human_assistant_agent",
            "other"
          ]
        },
        "agent_role": {
          "type": "string",
          "minLength": 1
        },
        "autonomy_level": {
          "type": "string",
          "enum": [
            "read_only",
            "recommendation_only",
            "manual_approval_required",
            "limited_execution",
            "unknown"
          ]
        }
      }
    },
    "intake": {
      "type": "object",
      "required": [
        "intake_id",
        "intake_status",
        "receipt_layers_detected",
        "missing_layers",
        "intake_summary"
      ],
      "additionalProperties": false,
      "properties": {
        "intake_id": {
          "type": "string",
          "pattern": "^intake_[A-Za-z0-9._-]+$"
        },
        "intake_status": {
          "type": "string",
          "enum": [
            "received",
            "parsed",
            "partial",
            "failed"
          ]
        },
        "receipt_layers_detected": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "origin",
              "trace",
              "transformation",
              "evidence",
              "transformation_diff",
              "audit",
              "royalty_hook",
              "royalty_handoff",
              "human_review_gate",
              "boundary",
              "handoff",
              "validation"
            ]
          }
        },
        "missing_layers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "intake_summary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "gate_check": {
      "type": "object",
      "required": [
        "gate_check_id",
        "human_review_gate_status",
        "decision_status",
        "blocking_conditions_detected",
        "permitted_actions",
        "blocked_actions",
        "gate_summary"
      ],
      "additionalProperties": false,
      "properties": {
        "gate_check_id": {
          "type": "string",
          "pattern": "^gate_check_[A-Za-z0-9._-]+$"
        },
        "human_review_gate_status": {
          "type": "string",
          "enum": [
            "not_required",
            "required",
            "pending",
            "passed",
            "rejected",
            "blocked",
            "unknown"
          ]
        },
        "decision_status": {
          "type": "string",
          "enum": [
            "not_started",
            "pending",
            "approved",
            "approved_with_conditions",
            "rejected",
            "blocked",
            "unknown"
          ]
        },
        "blocking_conditions_detected": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "condition_id",
              "condition_type",
              "severity",
              "blocks_actions"
            ],
            "additionalProperties": false,
            "properties": {
              "condition_id": {
                "type": "string"
              },
              "condition_type": {
                "type": "string"
              },
              "severity": {
                "type": "string",
                "enum": [
                  "low",
                  "medium",
                  "high",
                  "critical"
                ]
              },
              "blocks_actions": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        },
        "permitted_actions": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "archive_only",
              "internal_use",
              "attribution_publication",
              "license_publication",
              "market_registration",
              "royalty_handoff",
              "external_settlement",
              "agent_auto_handoff",
              "other"
            ]
          }
        },
        "blocked_actions": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "market_registration",
              "license_publication",
              "commercial_use",
              "training_use",
              "royalty_execution",
              "external_settlement",
              "public_origin_claim",
              "agent_auto_handoff",
              "other"
            ]
          }
        },
        "gate_summary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "routing": {
      "type": "object",
      "required": [
        "routing_id",
        "routing_status",
        "candidate_targets",
        "selected_targets",
        "routing_summary"
      ],
      "additionalProperties": false,
      "properties": {
        "routing_id": {
          "type": "string",
          "pattern": "^routing_[A-Za-z0-9._-]+$"
        },
        "routing_status": {
          "type": "string",
          "enum": [
            "not_started",
            "candidate_only",
            "ready_for_manual_review",
            "blocked",
            "completed"
          ]
        },
        "candidate_targets": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "target_id",
              "target_protocol",
              "target_purpose",
              "routing_readiness"
            ],
            "additionalProperties": false,
            "properties": {
              "target_id": {
                "type": "string",
                "pattern": "^target_[A-Za-z0-9._-]+$"
              },
              "target_protocol": {
                "type": "string",
                "enum": [
                  "synchronization-audit-protocol",
                  "origin-structure-market",
                  "origin-license-policy-registry",
                  "compute-access-royalty-os",
                  "royalty-os",
                  "multi-wing-orchestration-generator",
                  "external_registry",
                  "other"
                ]
              },
              "target_purpose": {
                "type": "string",
                "enum": [
                  "audit",
                  "licensing",
                  "market_registration",
                  "royalty_review",
                  "archival",
                  "orchestration",
                  "other"
                ]
              },
              "routing_readiness": {
                "type": "string",
                "enum": [
                  "ready",
                  "manual_review_required",
                  "blocked",
                  "not_applicable"
                ]
              },
              "routing_notes": {
                "type": "string"
              }
            }
          }
        },
        "selected_targets": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^target_[A-Za-z0-9._-]+$"
          }
        },
        "routing_summary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "route_authorization": {
      "type": "object",
      "required": [
        "authorization_id",
        "authorization_status",
        "authorization_mode",
        "authorization_records",
        "authorization_summary"
      ],
      "additionalProperties": false,
      "properties": {
        "authorization_id": {
          "type": "string",
          "pattern": "^route_auth_[A-Za-z0-9._-]+$"
        },
        "authorization_status": {
          "type": "string",
          "enum": [
            "draft",
            "candidate_only",
            "partially_authorized",
            "authorized",
            "blocked",
            "requires_human_review"
          ]
        },
        "authorization_mode": {
          "type": "string",
          "enum": [
            "record_only",
            "recommendation_only",
            "manual_approval_required",
            "gate_pass_required",
            "mixed"
          ]
        },
        "authorization_records": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "route_id",
              "target_id",
              "target_protocol",
              "target_purpose",
              "authorization_decision",
              "gate_dependency",
              "permitted_route_actions",
              "blocked_route_actions",
              "authorization_rationale"
            ],
            "additionalProperties": false,
            "properties": {
              "route_id": {
                "type": "string",
                "pattern": "^route_[A-Za-z0-9._-]+$"
              },
              "target_id": {
                "type": "string",
                "pattern": "^target_[A-Za-z0-9._-]+$"
              },
              "target_protocol": {
                "type": "string",
                "enum": [
                  "synchronization-audit-protocol",
                  "origin-structure-market",
                  "origin-license-policy-registry",
                  "compute-access-royalty-os",
                  "royalty-os",
                  "multi-wing-orchestration-generator",
                  "external_registry",
                  "other"
                ]
              },
              "target_purpose": {
                "type": "string",
                "enum": [
                  "audit",
                  "licensing",
                  "market_registration",
                  "royalty_review",
                  "archival",
                  "orchestration",
                  "other"
                ]
              },
              "authorization_decision": {
                "type": "string",
                "enum": [
                  "authorized",
                  "conditionally_authorized",
                  "manual_review_required",
                  "blocked",
                  "not_applicable"
                ]
              },
              "gate_dependency": {
                "type": "object",
                "required": [
                  "requires_human_gate_pass",
                  "accepted_gate_statuses",
                  "required_decision_statuses"
                ],
                "additionalProperties": false,
                "properties": {
                  "requires_human_gate_pass": {
                    "type": "boolean"
                  },
                  "accepted_gate_statuses": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "enum": [
                        "not_required",
                        "required",
                        "pending",
                        "passed",
                        "rejected",
                        "blocked",
                        "unknown"
                      ]
                    }
                  },
                  "required_decision_statuses": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "enum": [
                        "not_started",
                        "pending",
                        "approved",
                        "approved_with_conditions",
                        "rejected",
                        "blocked",
                        "unknown"
                      ]
                    }
                  }
                }
              },
              "permitted_route_actions": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "send_to_audit_queue",
                    "send_to_human_review_queue",
                    "create_review_ticket",
                    "emit_recommendation",
                    "archive_record",
                    "notify_reviewer",
                    "other"
                  ]
                }
              },
              "blocked_route_actions": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "register_market_asset",
                    "publish_license",
                    "execute_royalty",
                    "execute_external_settlement",
                    "approve_training_use",
                    "make_public_origin_claim",
                    "auto_forward_external",
                    "other"
                  ]
                }
              },
              "authorization_conditions": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "condition_id",
                    "condition_summary"
                  ],
                  "additionalProperties": false,
                  "properties": {
                    "condition_id": {
                      "type": "string",
                      "pattern": "^auth_condition_[A-Za-z0-9._-]+$"
                    },
                    "condition_summary": {
                      "type": "string",
                      "minLength": 1
                    }
                  }
                }
              },
              "authorization_rationale": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "authorization_summary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "reviewer_notification": {
      "type": "object",
      "required": [
        "notification_id",
        "notification_status",
        "notification_mode",
        "review_requests",
        "notification_summary"
      ],
      "additionalProperties": false,
      "properties": {
        "notification_id": {
          "type": "string",
          "pattern": "^review_notify_[A-Za-z0-9._-]+$"
        },
        "notification_status": {
          "type": "string",
          "enum": [
            "draft",
            "prepared",
            "queued",
            "sent",
            "deferred",
            "blocked",
            "not_required"
          ]
        },
        "notification_mode": {
          "type": "string",
          "enum": [
            "record_only",
            "recommendation_only",
            "manual_send_required",
            "agent_may_notify",
            "external_system",
            "mixed"
          ]
        },
        "review_requests": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "request_id",
              "reviewer_role",
              "review_reason",
              "priority",
              "related_routes",
              "requested_decision",
              "safe_notification_payload",
              "blocked_payload_items",
              "request_status"
            ],
            "additionalProperties": false,
            "properties": {
              "request_id": {
                "type": "string",
                "pattern": "^review_request_[A-Za-z0-9._-]+$"
              },
              "reviewer_role": {
                "type": "string",
                "enum": [
                  "originator",
                  "maintainer",
                  "auditor",
                  "legal_reviewer",
                  "market_operator",
                  "royalty_operator",
                  "human_gatekeeper",
                  "multi_party_review",
                  "other"
                ]
              },
              "review_reason": {
                "type": "string",
                "enum": [
                  "human_gate_pending",
                  "blocked_route",
                  "conditional_route",
                  "missing_recipient_identity",
                  "license_policy_review",
                  "market_registration_review",
                  "royalty_execution_review",
                  "training_use_review",
                  "conflicting_claims",
                  "low_evidence_confidence",
                  "custom_policy",
                  "other"
                ]
              },
              "priority": {
                "type": "string",
                "enum": [
                  "low",
                  "medium",
                  "high",
                  "critical"
                ]
              },
              "related_routes": {
                "type": "array",
                "items": {
                  "type": "string",
                  "pattern": "^route_[A-Za-z0-9._-]+$"
                }
              },
              "related_blocking_conditions": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "requested_decision": {
                "type": "string",
                "enum": [
                  "approve",
                  "approve_with_conditions",
                  "reject",
                  "block",
                  "request_more_evidence",
                  "assign_reviewer",
                  "other"
                ]
              },
              "notification_channel": {
                "type": "string",
                "enum": [
                  "none",
                  "issue",
                  "pull_request_comment",
                  "email",
                  "dashboard",
                  "webhook",
                  "manual",
                  "other"
                ]
              },
              "safe_notification_payload": {
                "type": "object",
                "required": [
                  "title",
                  "summary",
                  "included_fields"
                ],
                "additionalProperties": false,
                "properties": {
                  "title": {
                    "type": "string",
                    "minLength": 1
                  },
                  "summary": {
                    "type": "string",
                    "minLength": 1
                  },
                  "included_fields": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "enum": [
                        "source_receipt_id",
                        "receipt_schema_version",
                        "gate_status",
                        "decision_status",
                        "blocked_actions",
                        "candidate_targets",
                        "authorization_summary",
                        "routing_summary",
                        "evidence_summary",
                        "diff_summary",
                        "boundary_summary",
                        "other"
                      ]
                    }
                  }
                }
              },
              "blocked_payload_items": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "private_conversation_excerpt",
                    "unredacted_evidence",
                    "sensitive_identity",
                    "external_settlement_details",
                    "unverified_origin_claim",
                    "confidential_repository_url",
                    "other"
                  ]
                }
              },
              "request_status": {
                "type": "string",
                "enum": [
                  "draft",
                  "ready",
                  "sent",
                  "deferred",
                  "blocked",
                  "resolved"
                ]
              },
              "request_notes": {
                "type": "string"
              }
            }
          }
        },
        "notification_summary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "handoff_receipt_emission": {
      "type": "object",
      "required": [
        "emission_id",
        "emission_status",
        "emission_mode",
        "emitted_receipts",
        "emission_policy",
        "emission_summary"
      ],
      "additionalProperties": false,
      "properties": {
        "emission_id": {
          "type": "string",
          "pattern": "^handoff_emission_[A-Za-z0-9._-]+$"
        },
        "emission_status": {
          "type": "string",
          "enum": [
            "draft",
            "prepared",
            "emitted",
            "deferred",
            "blocked",
            "not_required"
          ]
        },
        "emission_mode": {
          "type": "string",
          "enum": [
            "record_only",
            "recommendation_only",
            "manual_emit_required",
            "agent_may_emit_internal",
            "external_system",
            "mixed"
          ]
        },
        "emitted_receipts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "emitted_receipt_id",
              "receipt_type",
              "target_protocol",
              "target_purpose",
              "related_route_id",
              "emission_decision",
              "payload_scope",
              "review_dependency",
              "emission_rationale"
            ],
            "additionalProperties": false,
            "properties": {
              "emitted_receipt_id": {
                "type": "string",
                "pattern": "^emitted_receipt_[A-Za-z0-9._-]+$"
              },
              "receipt_type": {
                "type": "string",
                "enum": [
                  "audit_handoff_receipt",
                  "review_request_receipt",
                  "royalty_review_receipt",
                  "license_review_receipt",
                  "market_review_receipt",
                  "archive_receipt",
                  "blocked_route_receipt",
                  "other"
                ]
              },
              "target_protocol": {
                "type": "string",
                "enum": [
                  "synchronization-audit-protocol",
                  "origin-structure-market",
                  "origin-license-policy-registry",
                  "compute-access-royalty-os",
                  "royalty-os",
                  "multi-wing-orchestration-generator",
                  "external_registry",
                  "other"
                ]
              },
              "target_purpose": {
                "type": "string",
                "enum": [
                  "audit",
                  "review",
                  "licensing",
                  "market_registration_review",
                  "royalty_review",
                  "archival",
                  "orchestration",
                  "blocked_route_record",
                  "other"
                ]
              },
              "related_route_id": {
                "type": "string",
                "pattern": "^route_[A-Za-z0-9._-]+$"
              },
              "related_review_request_ids": {
                "type": "array",
                "items": {
                  "type": "string",
                  "pattern": "^review_request_[A-Za-z0-9._-]+$"
                }
              },
              "emission_decision": {
                "type": "string",
                "enum": [
                  "emit_internal",
                  "prepare_for_manual_emit",
                  "defer",
                  "block",
                  "not_applicable"
                ]
              },
              "payload_scope": {
                "type": "object",
                "required": [
                  "included_fields",
                  "excluded_fields",
                  "redaction_required"
                ],
                "additionalProperties": false,
                "properties": {
                  "included_fields": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "enum": [
                        "source_receipt_id",
                        "receipt_schema_version",
                        "agent_context",
                        "gate_status",
                        "decision_status",
                        "routing_summary",
                        "authorization_summary",
                        "notification_summary",
                        "blocked_actions",
                        "permitted_actions",
                        "candidate_targets",
                        "selected_targets",
                        "safe_notification_payload",
                        "other"
                      ]
                    }
                  },
                  "excluded_fields": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "enum": [
                        "private_conversation_excerpt",
                        "unredacted_evidence",
                        "sensitive_identity",
                        "external_settlement_details",
                        "unverified_origin_claim",
                        "confidential_repository_url",
                        "other"
                      ]
                    }
                  },
                  "redaction_required": {
                    "type": "boolean"
                  }
                }
              },
              "review_dependency": {
                "type": "object",
                "required": [
                  "requires_human_review",
                  "requires_gate_pass",
                  "allowed_before_gate_pass"
                ],
                "additionalProperties": false,
                "properties": {
                  "requires_human_review": {
                    "type": "boolean"
                  },
                  "requires_gate_pass": {
                    "type": "boolean"
                  },
                  "allowed_before_gate_pass": {
                    "type": "boolean"
                  },
                  "dependency_notes": {
                    "type": "string"
                  }
                }
              },
              "emission_reference": {
                "type": "string"
              },
              "emission_rationale": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "emission_policy": {
          "type": "object",
          "required": [
            "default_emission_mode",
            "external_emission_allowed",
            "requires_safe_payload",
            "policy_notes"
          ],
          "additionalProperties": false,
          "properties": {
            "default_emission_mode": {
              "type": "string",
              "enum": [
                "record_only",
                "recommendation_only",
                "manual_emit_required",
                "internal_emit_allowed",
                "external_emit_allowed"
              ]
            },
            "external_emission_allowed": {
              "type": "boolean"
            },
            "requires_safe_payload": {
              "type": "boolean"
            },
            "policy_notes": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "emission_summary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "action_policy": {
      "type": "object",
      "required": [
        "execution_mode",
        "allowed_agent_actions",
        "prohibited_agent_actions",
        "policy_summary"
      ],
      "additionalProperties": false,
      "properties": {
        "execution_mode": {
          "type": "string",
          "enum": [
            "record_only",
            "recommendation_only",
            "manual_approval_required",
            "agent_execution_allowed"
          ]
        },
        "allowed_agent_actions": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "read_receipt",
              "validate_receipt",
              "summarize_receipt",
              "classify_gate_status",
              "recommend_targets",
              "emit_handoff_record",
              "notify_human_reviewer",
              "create_review_notification",
              "prepare_safe_payload",
              "request_human_review",
              "create_handoff_receipt",
              "prepare_downstream_receipt",
              "emit_internal_handoff_receipt",
              "other"
            ]
          }
        },
        "prohibited_agent_actions": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "execute_payment",
              "register_market_asset",
              "publish_license",
              "approve_training_use",
              "make_public_origin_claim",
              "bypass_human_review_gate",
              "auto_forward_to_external_system",
              "send_unredacted_private_evidence",
              "notify_external_system_without_review",
              "emit_external_handoff_without_review",
              "emit_receipt_with_unredacted_payload",
              "other"
            ]
          }
        },
        "policy_summary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "handoff_result": {
      "type": "object",
      "required": [
        "result_status",
        "emitted_records",
        "result_summary"
      ],
      "additionalProperties": false,
      "properties": {
        "result_status": {
          "type": "string",
          "enum": [
            "recorded",
            "recommended",
            "deferred",
            "blocked",
            "failed"
          ]
        },
        "emitted_records": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "result_summary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "validation_status": {
          "type": "string",
          "enum": [
            "draft",
            "validated",
            "rejected"
          ]
        },
        "record_hash": {
          "type": "string"
        }
      }
    }
  }
}
